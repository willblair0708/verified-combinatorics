P2<X,Y,Z> := ProjectiveSpace(Rationals(), 2);
F := X^5 - 5*X^3*Z^2 + 4*X*Z^4 - 4*(Y^5 - 5*Y^3*Z^2 + 4*Y*Z^4);
C := Curve(P2, F);
print "genus:", Genus(C);  // expect 6
Q<x> := PolynomialRing(Rationals());
for p in [7,11,13,17,19,23,29,31,37] do
  Cp := ChangeRing(C, GF(p));
  Lp := Numerator(ZetaFunction(Cp));
  print p, Factorisation(Q ! Lp);
end for;
